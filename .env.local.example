# =====================================================================
# 大脉 (damai) 本地环境变量模板
# 复制本文件为 .env.local, 填入真实值, 切勿提交 git
# =====================================================================

# ---------- 阿里云 SMS (短信验证码登录) ----------
# dev stub 模式默认开启 — 验证码直接返回前端 + console.log (开发够用)
# 切真实: 4 个 key 填好 + DAMI_SMS_REAL=true
DAMI_SMS_REAL=false
ALIYUN_SMS_ACCESS_KEY_ID=LTAI5xxxxxxxxxxxx
ALIYUN_SMS_ACCESS_KEY_SECRET=xxxxxx...xxxx
ALIYUN_SMS_SIGN_NAME=杭州即客传媒        # ⚠️ 必须跟营业执照全称一字不差
ALIYUN_SMS_TEMPLATE_CODE=SMS_xxxxxxxx   # 模板审核通过后填

# ---------- 火山方舟 (Seedream 5.0) ----------
VOLC_API_KEY=ark-xx...xxxx
# 可选: 自定义 base URL (默认 https://ark.cn-beijing.volces.com/api/v3)
# ARK_IMAGE_BASE_URL=
# 可选: 自定义模型 (默认 doubao-seedream-5-0-260128)
# ARK_IMAGE_MODEL=

# ---------- 阿里云 OSS (damai-zlh-prod, 杭州) ----------
# 从阿里云 RAM 控制台 → 用户 → AccessKey 创建
ALIYUN_OSS_ACCESS_KEY_ID=LTAI5xxxxxxxxxxxx
ALIYUN_OSS_ACCESS_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ALIYUN_OSS_REGION=oss-cn-hangzhou
ALIYUN_OSS_BUCKET=damai-zlh-prod
# 内网/外网 endpoint 自动 (region 默认), 高级用户可改
# ALIYUN_OSS_ENDPOINT=https://oss-cn-hangzhou-internal.aliyuncs.com  # ECS 内网走这个免流量费

# ---------- 飞书 webhook (告警用) ----------
FEISHU_ALERT_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxxxxxxxxxx

# ---------- NAS 备份 ----------
NAS_BACKUP_HOST=192.168.1.x   # NAS 内网 IP (走 VPN)
NAS_BACKUP_USER=zhanglh
NAS_BACKUP_PATH=/volume1/10T/Hermes/projects/damai-backup

# ---------- 阿里云 ARMS 错误上报 (07-03 user 拍板切换 Sentry → ARMS) ----------
# 阿里云原生监控, 跟阿里云账号集成, 不用单独注册
# 注册步骤 (5 分钟):
#   1. https://arms.console.aliyun.com/ 登录 (跟 RAM / OSS 同账号)
#   2. 前端监控 → 创建应用 (类型 Web/H5) → 拿到 AppId → 填 NEXT_PUBLIC_ARMS_APP_ID
#   3. 应用监控 → 创建应用 (类型 Node.js) → 拿到 LicenseKey → 填 ARMS_LICENSE_KEY
#   4. 飞书贴我 2 个值, 我写 .env.local + dev 触发测试

# 前端 (NEXT_PUBLIC_* 才会 inline 到 client bundle, 用户浏览器上报)
NEXT_PUBLIC_ARMS_APP_ID=xxxxxxxxxxxxx

# 后端 (server runtime, Node API 上报)
# ARMS 控制台 → 应用监控 → Node.js 应用 → LicenseKey
ARMS_LICENSE_KEY=xxxxxxxxxxxxx