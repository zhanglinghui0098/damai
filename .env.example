# 大脉 (damai) — 环境变量模板
# 复制为 .env.local 填入真值, .env.local 已 gitignore

# =============================================================================
# Session 签名密钥 (生产必填, dev 有兜底但生产必须设)
# 生成: openssl rand -hex 32
# =============================================================================
DAMI_SESSION_SECRET=change-me-to-a-random-32-byte-hex-string

# =============================================================================
# 短信服务 (阿里云) — 手机号登录用
# 申请流程: 阿里云控制台 → 短信服务 → 国内消息 → 签名管理 + 模板管理
#   1. 签名: 申请 "大脉" (审核 0.5-2 小时)
#   2. 模板: "您的验证码是${code}，5分钟内有效。" (审核 0.5-2 小时)
#   3. AccessKey: 阿里云控制台 → 右上角头像 → AccessKey 管理 → 创建
#
# dev_stub 模式 (默认): 不发真短信,验证码返回到前端 + 控制台打
#   设 DAMI_SMS_REAL=true 切到真实模式 (生产用)
# =============================================================================
DAMI_SMS_REAL=false
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=大脉
ALIYUN_SMS_TEMPLATE_CODE=SMS_xxxxxxx

